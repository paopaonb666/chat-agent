# ── 数据库 ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/chat_agent

# ── DeepSeek (对话 LLM) ────────────────────────────
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── 智谱 GLM-4 (备用 LLM) ─────────────────────────
ZHIPU_API_KEY=your_api_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPU_MODEL=glm-4

# ── Milvus (向量数据库) ────────────────────────────
MILVUS_URI=http://localhost:19530

# ── Ollama (本地 Embedding + Rerank) ───────────────
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=qwen3-embedding:0.6b
RERANK_MODEL=pdurugyan/qwen3-reranker-0.6b-q8_0
OLLAMA_LARGE_MODEL=qwen2.5:1.5b

# ── Tavily (联网搜索) ──────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here
SEARCH_ENGINE_PRIORITY=tavily,duckduckgo

# ── 安全 ───────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string

# ── 管理员账号 (首次启动自动创建) ────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── 硅基流动 (记忆意图识别) ──────────────────────
# 用于判断对话是否包含值得长期记忆的个人信息
SILICONFLOW_API_KEY=your_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct

# ── 记忆意图识别筛选 ──────────────────────────────
ENABLE_MEMORY_INTENT_FILTER=true

# ── CORS ───────────────────────────────────────────
# 逗号分隔的允许来源列表
CORS_ORIGINS=http://localhost:5173

# ── 运行环境 ───────────────────────────────────────
# development | production | testing
ENV=development

# ── LangGraph 代理 (实验性) ────────────────────────
USE_LANGGRAPH_AGENT=false

# ── 混合检索时间衰减 ──────────────────────────────
# 最新消息的 RRF 分数加成最大值 (0.0 ~ 1.0)
TIME_DECAY_MAX_BONUS=0.2
# 衰减窗口内的消息数量
TIME_DECAY_WINDOW_SIZE=200

# ── 日志 ───────────────────────────────────────────
# 日志文件路径，留空则仅输出到控制台
LOG_FILE=
# 单个日志文件最大大小 (字节)，默认 10MB
LOG_MAX_BYTES=10485760
# 保留的日志备份数量
LOG_BACKUP_COUNT=5
